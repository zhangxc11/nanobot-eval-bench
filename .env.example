# nanobot Eval Bench — 环境变量配置
# 复制为 .env 并填入实际值

# ════════════════════════════════════════════════════════
# [必须] 待评测的 LLM API 配置
# ════════════════════════════════════════════════════════
AGENT_API_KEY=sk-your-api-key-here
AGENT_API_BASE=https://your-api-base-url
AGENT_MODEL=your-model-name

# Provider 名称（anthropic, openai, deepseek, volcengine, openrouter）
AGENT_PROVIDER=anthropic

# ════════════════════════════════════════════════════════
# [可选] 任务配置
# ════════════════════════════════════════════════════════
# TASK_ID=task-001-doubao-search-skill
# MAX_TOOL_CALLS=150
# TIMEOUT_MINUTES=30

# ════════════════════════════════════════════════════════
# [可选] 路径配置
# ════════════════════════════════════════════════════════
# nanobot 源码路径（默认自动检测）
# NANOBOT_SRC_PATH=/path/to/nanobot

# 本地数据目录（测例 + 结果，默认 ../eval-bench-data/）
# EVAL_BENCH_DATA=/path/to/eval-bench-data

# ════════════════════════════════════════════════════════
# [可选] 国内镜像加速
# ════════════════════════════════════════════════════════
# DOCKER_MIRROR=docker.1ms.run/
# PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
