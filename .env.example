# nanobot Eval Bench — 环境变量配置
# 复制为 .env 并填入实际值

# ════════════════════════════════════════════════════════
# [必须] 驱动 agent 的 LLM API Key
# ════════════════════════════════════════════════════════
AGENT_API_KEY=sk-your-api-key-here

# ════════════════════════════════════════════════════════
# [可选] LLM Provider 配置
# ════════════════════════════════════════════════════════
# 可选值: anthropic, openai, deepseek, volcengine, openrouter
# AGENT_PROVIDER=anthropic

# 模型名（默认 claude-sonnet-4-20250514）
# AGENT_MODEL=claude-sonnet-4-20250514

# ════════════════════════════════════════════════════════
# [可选] 自定义 API Base URL
# ════════════════════════════════════════════════════════
# 使用代理或非默认 endpoint 时设置
# AGENT_API_BASE=https://your-proxy.com

# ─── 🔥 volcengine (火山方舟) 用户必读 ──────────────────
# 使用 volcengine provider 时，以下两项必须设置：
#
#   AGENT_PROVIDER=volcengine
#   AGENT_MODEL=ep-你的endpoint-id
#   AGENT_API_BASE=https://ark.cn-beijing.volces.com/api/v3
#
# 注意：runner.py 会自动处理 volcengine provider 与 mock API
# 的冲突问题（使用 custom provider 绕过），无需额外配置。
# ────────────────────────────────────────────────────────

# ─── 🌏 国内用户网络配置 ────────────────────────────────
# Docker Hub 镜像加速（构建 Docker 镜像时使用）
# DOCKER_MIRROR=docker.1ms.run/

# pip 镜像源（Docker 构建时使用）
# PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
# ────────────────────────────────────────────────────────

# ════════════════════════════════════════════════════════
# [可选] 任务与资源配置
# ════════════════════════════════════════════════════════
# TASK_ID=task-001-doubao-search-skill
# MAX_TOOL_CALLS=150
# TIMEOUT_MINUTES=30
